# Copy to apps/cms/.env.local and fill in values.
# Next.js loads: .env, then .env.local (local overrides).

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# PostHog analytics (optional — can also live in apps/cms/.env)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# OpenAI (optional — AI photo analysis & project generation)
OPENAI_API_KEY=

# Contact email via Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_EMAIL=
